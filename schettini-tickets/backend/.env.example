# ===========================================
# Backend - Sistema de Tickets - Variables de entorno
# Copia este archivo a .env y completa los valores.
# ===========================================

# Puerto (en hosting suele venir por variable PORT)
PORT=5050

# JWT para sesiones (genera uno seguro: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=tu_clave_secreta_muy_larga_y_aleatoria

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=schettini_tickets
# Activar SSL para MySQL en la nube (ej. Render, Railway)
DB_SSL=false

# Email (Nodemailer) — tickets, comentarios, activación, recuperación de clave, etc.
# Usar siempre EMAIL_* (puerto 587 → STARTTLS; el backend usa secure: false salvo 465).
EMAIL_HOST=smtp.ejemplo.com
EMAIL_PORT=587
EMAIL_USER=tu_email@ejemplo.com
EMAIL_PASS=tu_password_de_aplicacion
# Remitente visible (opcional; si no se define se usa EMAIL_USER)
# EMAIL_FROM=noreply@tudominio.com

# URL del frontend (para links en emails)
FRONTEND_URL=http://localhost:3000

# Fallback si no hay email en Admin → Configuración (sales_notification_email) para avisos "Me interesa" en ofertas
# SALES_NOTIFICATION_EMAIL=ventas@tuempresa.com

# Orígenes CORS adicionales (opcional, separados por coma)
# CORS_ORIGINS=https://mitienda.com,https://app.mitienda.com

# Entorno
NODE_ENV=development
